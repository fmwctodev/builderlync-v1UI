# API Configuration
VITE_API_URL=http://localhost:3000/api

# Google OAuth Configuration
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Microsoft OAuth Configuration
VITE_MICROSOFT_CLIENT_ID=your_microsoft_client_id_here

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Staging auth bypass (auto-login a mock user)
#
# When set to "1" or "true", the app skips the login screen and auto-populates
# the auth state with a mock staff user, plus a mock organization. This is
# also auto-enabled by hostname for known staging URLs:
#   - bl-v2.netlify.app
#   - localhost / 127.0.0.1
#   - deploy-preview-*--*.netlify.app
#
# Set to "0" or "false" to FORCE-DISABLE the bypass (useful when testing the
# real login flow on a staging host).
#
# NEVER set this to "1" on production. Production hostnames (app.builderlync.com,
# etc.) are not in the auto-enable list, so the bypass stays off there by default.
VITE_BYPASS_AUTH=0
